-    "    raw_data = game.get_slm_payload()\n",
-    "    \n",
-    "    # Initialize the conversation history for this year\n",
-    "    messages = [\n",
-    "        {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
-    "        {\"role\": \"user\", \"content\": f\"Current Kingdom Status:\\n{raw_data}\"}\n",
-    "    ]\n",
-    "    \n",
