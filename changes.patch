-    "    print(\"=\"*40)\n",
-    "    \n",
-    "    decree_accepted = False\n",
-    "    \n",
-    "    # The AI Retry Loop\n",
-    "    while not decree_accepted:\n",
-    "        text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True, enable_thinking=True)\n",
-    "        inputs = processor(text=text, return_tensors=\"pt\").to(model.device)\n",
-    "        \n",
-    "        streamer = TextStreamer(processor, skip_prompt=True, skip_special_tokens=True)\n",
-    "        outputs = model.generate(**inputs, max_new_tokens=4096, streamer=streamer)\n",
